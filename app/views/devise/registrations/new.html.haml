.container.vh-100
  .row.vh-100.align-items-center
    .col-md-4.mx-auto.mb-5
      %h2= t("devise.sessions.new.sign_in")
      = simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
        = f.error_notification
        = f.input :email, required: true, autofocus: true, placeholder: t("devise.attributes.user.email")
        = f.input :password, required: true, hint: ("#{@minimum_password_length} minimum" if @minimum_password_length), placeholder: t("devise.attributes.user.password")
        = f.input :password_confirmation, required: true, placeholder: t("devise.attributes.user.password_confirmation")
        = f.button :submit
      = render "devise/shared/links"
